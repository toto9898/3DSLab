# Doxyfile for 3DSLab
# Run: doxygen docs/Doxyfile  (from the project root)

#---------------------------------------------------------------------------
# Project
#---------------------------------------------------------------------------
PROJECT_NAME           = "3DSLab"
PROJECT_BRIEF          = "3DS file importer and viewer"
PROJECT_NUMBER         =
OUTPUT_DIRECTORY       = docs/generated

#---------------------------------------------------------------------------
# Input
#---------------------------------------------------------------------------
INPUT                  = src/Core \
                         src/Scene \
                         src/Scene/Animation \
                         src/Parser \
                         src/Parser/Chunks \
                         src/Rendering \
                         src/UI
RECURSIVE              = YES
FILE_PATTERNS          = *.h *.cpp
EXCLUDE_PATTERNS       = */imgui_impl_bgfx*

#---------------------------------------------------------------------------
# Output formats
#---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO

#---------------------------------------------------------------------------
# Extraction
#---------------------------------------------------------------------------
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

#---------------------------------------------------------------------------
# Source browsing
#---------------------------------------------------------------------------
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCES_RELATION    = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES

#---------------------------------------------------------------------------
# Diagrams (requires Graphviz dot)
#---------------------------------------------------------------------------
HAVE_DOT               = YES
DOT_PATH               = C:/Program Files/Graphviz/bin
DOT_NUM_THREADS        = 4
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
GRAPHICAL_HIERARCHY    = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
DOT_GRAPH_MAX_NODES    = 100

#---------------------------------------------------------------------------
# Preprocessing
#---------------------------------------------------------------------------
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO
PREDEFINED             = EIGEN_STRONG_INLINE=inline

#---------------------------------------------------------------------------
# Warnings
#---------------------------------------------------------------------------
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO
